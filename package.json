{
	"name": "lolzteam-api",
	"version": "0.0.0-dev",
	"description": "TypeScript API wrapper for Lolzteam Forum and Market",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./forum": {
			"types": "./dist/generated/forum/index.d.ts",
			"import": "./dist/generated/forum/index.js"
		},
		"./market": {
			"types": "./dist/generated/market/index.d.ts",
			"import": "./dist/generated/market/index.js"
		}
	},
	"sideEffects": false,
	"files": ["dist"],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --fix .",
		"lint:check": "biome check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"codegen": "tsx codegen/src/index.ts",
		"prepublishOnly": "pnpm run build"
	},
	"keywords": ["lolzteam", "lolz", "zelenka", "api", "wrapper"],
	"license": "MIT",
	"packageManager": "pnpm@10.28.2",
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^22.0.0",
		"tsx": "^4.0.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
